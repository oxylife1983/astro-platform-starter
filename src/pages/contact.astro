---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contactez-nous - Boissons Express">
  <h1 class="mb-8">Contactez-nous</h1>
  
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-16">
    <!-- Contact Form -->
    <div>
      <div class="bg-gray-800 rounded-lg p-6">
        <h2 class="text-xl font-semibold mb-6">Envoyez-nous un message</h2>
        
        <form id="contact-form" class="space-y-4">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="name" class="block text-sm font-medium mb-1">Nom complet</label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                required 
                class="w-full px-4 py-2 bg-gray-700 border border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium mb-1">Email</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required 
                class="w-full px-4 py-2 bg-gray-700 border border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary"
              />
            </div>
          </div>
          
          <div>
            <label for="phone" class="block text-sm font-medium mb-1">Tu00e9lu00e9phone</label>
            <input 
              type="tel" 
              id="phone" 
              name="phone" 
              placeholder="+225 XX XX XX XX XX" 
              class="w-full px-4 py-2 bg-gray-700 border border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary"
            />
          </div>
          
          <div>
            <label for="subject" class="block text-sm font-medium mb-1">Sujet</label>
            <select 
              id="subject" 
              name="subject" 
              required 
              class="w-full px-4 py-2 bg-gray-700 border border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary"
            >
              <option value="">Su00e9lectionnez un sujet</option>
              <option value="commande">Question sur une commande</option>
              <option value="produits">Renseignements sur les produits</option>
              <option value="livraison">Informations de livraison</option>
              <option value="partenariat">Proposition de partenariat</option>
              <option value="autre">Autre</option>
            </select>
          </div>
          
          <div>
            <label for="message" class="block text-sm font-medium mb-1">Message</label>
            <textarea 
              id="message" 
              name="message" 
              rows="5" 
              required 
              class="w-full px-4 py-2 bg-gray-700 border border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary"
            ></textarea>
          </div>
          
          <button type="submit" class="btn w-full py-3">
            Envoyer le message
          </button>
        </form>
      </div>
    </div>
    
    <!-- Contact Information -->
    <div>
      <div class="bg-gray-800 rounded-lg p-6 mb-8">
        <h2 class="text-xl font-semibold mb-6">Nos coordonnu00e9es</h2>
        
        <div class="space-y-6">
          <div class="flex items-start">
            <div class="bg-primary text-primary-content rounded-full w-10 h-10 flex items-center justify-center mr-4 mt-1 flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-lg mb-1">Adresse</h3>
              <p class="text-gray-300">123 Boulevard Principal</p>
              <p class="text-gray-300">Cocody, Abidjan</p>
              <p class="text-gray-300">Cu00f4te d'Ivoire</p>
            </div>
          </div>
          
          <div class="flex items-start">
            <div class="bg-primary text-primary-content rounded-full w-10 h-10 flex items-center justify-center mr-4 mt-1 flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-lg mb-1">Tu00e9lu00e9phone</h3>
              <p class="text-gray-300">+225 07 12 34 56 78</p>
              <p class="text-gray-300">+225 05 98 76 54 32</p>
            </div>
          </div>
          
          <div class="flex items-start">
            <div class="bg-primary text-primary-content rounded-full w-10 h-10 flex items-center justify-center mr-4 mt-1 flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-lg mb-1">Email</h3>
              <p class="text-gray-300">contact@boissons-express.ci</p>
              <p class="text-gray-300">info@boissons-express.ci</p>
            </div>
          </div>
          
          <div class="flex items-start">
            <div class="bg-primary text-primary-content rounded-full w-10 h-10 flex items-center justify-center mr-4 mt-1 flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-lg mb-1">Heures d'ouverture</h3>
              <p class="text-gray-300">Lundi - Vendredi: 8h00 - 18h00</p>
              <p class="text-gray-300">Samedi: 9h00 - 15h00</p>
              <p class="text-gray-300">Dimanche: Fermu00e9</p>
            </div>
          </div>
        </div>
      </div>
      
      <div class="bg-gray-800 rounded-lg p-6">
        <h2 class="text-xl font-semibold mb-6">Suivez-nous</h2>
        
        <div class="flex space-x-4">
          <a href="#" class="bg-gray-700 hover:bg-primary text-white hover:text-primary-content p-3 rounded-full transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/>
            </svg>
          </a>
          <a href="#" class="bg-gray-700 hover:bg-primary text-white hover:text-primary-content p-3 rounded-full transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/>
            </svg>
          </a>
          <a href="#" class="bg-gray-700 hover:bg-primary text-white hover:text-primary-content p-3 rounded-full transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a href="#" class="bg-gray-700 hover:bg-primary text-white hover:text-primary-content p-3 rounded-full transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Map Section -->
  <div class="mb-16">
    <h2 class="text-2xl font-bold mb-6">Notre emplacement</h2>
    <div class="bg-gray-800 rounded-lg overflow-hidden h-96">
      <!-- Placeholder for a map (in a real app, you would integrate Google Maps or similar) -->
      <div class="w-full h-full bg-gray-700 flex items-center justify-center">
        <p class="text-gray-400">Carte interactive sera affichée ici</p>
      </div>
    </div>
  </div>
  
  <!-- Success Message Modal (hidden by default) -->
  <div id="success-modal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 hidden">
    <div class="bg-gray-800 rounded-lg p-8 max-w-md w-full">
      <div class="text-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mx-auto mb-4 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h2 class="text-2xl font-bold mb-4">Message Envoyé!</h2>
        <p class="mb-6">Merci de nous avoir contacté. Nous vous répondrons dans les plus brefs délais.</p>
        <button id="close-modal" class="btn w-full">Fermer</button>
      </div>
    </div>
  </div>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const contactForm = document.getElementById('contact-form');
    const successModal = document.getElementById('success-modal');
    const closeModalBtn = document.getElementById('close-modal');
    
    if (contactForm) {
      contactForm.addEventListener('submit', (event) => {
        event.preventDefault();
        
        // In a real app, you would send the form data to a server
        // For this demo, we'll just show the success message
        
        // Show success modal
        if (successModal) {
          successModal.classList.remove('hidden');
        }
        
        // Reset form
        contactForm.reset();
      });
    }
    
    if (closeModalBtn && successModal) {
      closeModalBtn.addEventListener('click', () => {
        successModal.classList.add('hidden');
      });
    }
  });
</script>