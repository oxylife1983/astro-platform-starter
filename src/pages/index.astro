---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import Newsletter from '../components/Newsletter.astro';
import ProductRecommendations from '../components/ProductRecommendations.astro';
import { getFeaturedProducts } from '../data/products';

const featuredProducts = getFeaturedProducts();
---

<Layout title="Boissons Express - Vente en Gros pour Pharmacies en Côte d'Ivoire">
    <!-- Hero Section -->
    <section class="py-12 mb-16 text-center">
        <h1 class="mb-6">Boissons Express</h1>
        <p class="text-xl mb-8 max-w-3xl mx-auto text-gray-300">
            Fournisseur de boissons en gros pour les pharmacies et commerces en Côte d'Ivoire.
            Livraison rapide de cartons de 24 canettes à Abidjan et ses environs.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
            <a href="/produits" class="btn btn-lg">Voir nos produits</a>
            <a href="/contact" class="btn btn-lg bg-gray-700 hover:bg-gray-600">Nous contacter</a>
        </div>
    </section>

    <!-- Featured Products -->
    <section class="mb-16">
        <h2 class="mb-8 text-center">Produits Populaires</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
            {featuredProducts.map(product => (
                <ProductCard product={product} />
            ))}
        </div>
        <div class="mt-10 text-center">
            <a href="/produits" class="btn">Voir tous les produits</a>
        </div>
    </section>

    <!-- Why Choose Us -->
    <section class="mb-16 bg-gray-800 p-8 rounded-lg">
        <h2 class="mb-8 text-center">Pourquoi Nous Choisir?</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="text-center p-6">
                <div class="bg-primary text-primary-content rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                <h3 class="text-xl font-semibold mb-2">Livraison Rapide</h3>
                <p class="text-gray-400">Livraison en 24h à Abidjan et 48h dans les autres régions.</p>
            </div>
            <div class="text-center p-6">
                <div class="bg-primary text-primary-content rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                <h3 class="text-xl font-semibold mb-2">Prix Compétitifs</h3>
                <p class="text-gray-400">Les meilleurs prix du marché pour les achats en gros.</p>
            </div>
            <div class="text-center p-6">
                <div class="bg-primary text-primary-content rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                    </svg>
                </div>
                <h3 class="text-xl font-semibold mb-2">Qualité Garantie</h3>
                <p class="text-gray-400">Produits frais avec dates de péremption optimales.</p>
            </div>
        </div>
    </section>
    
    <!-- Categories Section -->
    <section class="mb-16">
        <h2 class="mb-8 text-center">Nos Catégories</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
            <a href="/produits/categorie/sodas" class="bg-gray-800 rounded-lg overflow-hidden group hover:bg-gray-700 transition-colors">
                <div class="aspect-video bg-gray-700 relative overflow-hidden">
                    <img 
                        src="/images/products/category-sodas.jpg" 
                        alt="Sodas" 
                        class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                        onerror="this.src='/images/product-placeholder.jpg'; this.onerror='';"
                    />
                </div>
                <div class="p-6 text-center">
                    <h3 class="text-xl font-semibold mb-2">Sodas</h3>
                    <p class="text-gray-400 mb-4">Coca-Cola, Fanta, Sprite et plus</p>
                    <span class="text-primary font-medium">Voir les produits</span>
                </div>
            </a>
            
            <a href="/produits/categorie/eau" class="bg-gray-800 rounded-lg overflow-hidden group hover:bg-gray-700 transition-colors">
                <div class="aspect-video bg-gray-700 relative overflow-hidden">
                    <img 
                        src="/images/products/category-water.jpg" 
                        alt="Eau" 
                        class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                        onerror="this.src='/images/product-placeholder.jpg'; this.onerror='';"
                    />
                </div>
                <div class="p-6 text-center">
                    <h3 class="text-xl font-semibold mb-2">Eau</h3>
                    <p class="text-gray-400 mb-4">Eau minérale et eau gazeuse</p>
                    <span class="text-primary font-medium">Voir les produits</span>
                </div>
            </a>
            
            <a href="/produits/categorie/jus" class="bg-gray-800 rounded-lg overflow-hidden group hover:bg-gray-700 transition-colors">
                <div class="aspect-video bg-gray-700 relative overflow-hidden">
                    <img 
                        src="/images/products/category-juice.jpg" 
                        alt="Jus" 
                        class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                        onerror="this.src='/images/product-placeholder.jpg'; this.onerror='';"
                    />
                </div>
                <div class="p-6 text-center">
                    <h3 class="text-xl font-semibold mb-2">Jus</h3>
                    <p class="text-gray-400 mb-4">Jus de fruits naturels</p>
                    <span class="text-primary font-medium">Voir les produits</span>
                </div>
            </a>
        </div>
    </section>

    <!-- Newsletter Section -->
    <Newsletter />

    <!-- Call to Action -->
    <section class="mb-16 text-center bg-primary text-primary-content p-10 rounded-lg">
        <h2 class="mb-4">Prêt à commander?</h2>
        <p class="text-lg mb-6">Rejoignez les pharmacies qui nous font confiance pour leurs approvisionnements.</p>
        <a href="/produits" class="btn bg-white text-primary-content hover:bg-gray-100 btn-lg">Commander maintenant</a>
    </section>
</Layout>
