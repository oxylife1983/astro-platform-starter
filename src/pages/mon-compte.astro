---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Mon Compte - Boissons Express">
  <h1 class="mb-8">Mon Compte</h1>
  
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Sidebar Navigation -->
    <div class="lg:col-span-1">
      <div class="bg-gray-800 rounded-lg p-6">
        <div class="mb-6 text-center">
          <div class="bg-gray-700 rounded-full w-24 h-24 mx-auto mb-4 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
          <h2 class="text-xl font-semibold mb-1 user-name">Chargement...</h2>
          <p class="text-gray-400 user-email">Chargement...</p>
        </div>
        
        <nav>
          <ul class="space-y-2">
            <li>
              <button 
                data-tab="dashboard" 
                class="w-full text-left px-4 py-3 rounded-md bg-primary text-primary-content font-medium flex items-center account-tab-btn"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
                Tableau de bord
              </button>
            </li>
            <li>
              <button 
                data-tab="orders" 
                class="w-full text-left px-4 py-3 rounded-md hover:bg-gray-700 font-medium flex items-center account-tab-btn"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                </svg>
                Mes commandes
              </button>
            </li>
            <li>
              <button 
                data-tab="profile" 
                class="w-full text-left px-4 py-3 rounded-md hover:bg-gray-700 font-medium flex items-center account-tab-btn"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
                Mon profil
              </button>
            </li>
            <li>
              <button 
                data-tab="addresses" 
                class="w-full text-left px-4 py-3 rounded-md hover:bg-gray-700 font-medium flex items-center account-tab-btn"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                Adresses
              </button>
            </li>
          </ul>
        </nav>
        
        <div class="mt-8 pt-6 border-t border-gray-700">
          <button id="logout-btn" class="w-full text-left px-4 py-3 rounded-md hover:bg-gray-700 text-red-400 hover:text-red-300 font-medium flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
            Du00e9connexion
          </button>
        </div>
      </div>
    </div>
    
    <!-- Content Area -->
    <div class="lg:col-span-2">
      <!-- Dashboard Tab -->
      <div id="dashboard-tab" class="account-tab">
        <div class="bg-gray-800 rounded-lg p-6 mb-8">
          <h2 class="text-xl font-semibold mb-6">Tableau de bord</h2>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-gray-700 rounded-lg p-4">
              <h3 class="font-medium mb-2">Commandes ru00e9centes</h3>
              <p class="text-2xl font-bold">3</p>
            </div>
            <div class="bg-gray-700 rounded-lg p-4">
              <h3 class="font-medium mb-2">Total du00e9pensu00e9</h3>
              <p class="text-2xl font-bold">145 000 CFA</p>
            </div>
          </div>
        </div>
        
        <div class="bg-gray-800 rounded-lg p-6">
          <h2 class="text-xl font-semibold mb-6">Activitu00e9 ru00e9cente</h2>
          
          <div class="space-y-4">
            <div class="border-l-4 border-green-500 pl-4 py-1">
              <p class="font-medium">Commande #12345 livru00e9e</p>
              <p class="text-sm text-gray-400">Il y a 2 jours</p>
            </div>
            <div class="border-l-4 border-yellow-500 pl-4 py-1">
              <p class="font-medium">Commande #12346 en cours de livraison</p>
              <p class="text-sm text-gray-400">Il y a 5 jours</p>
            </div>
            <div class="border-l-4 border-blue-500 pl-4 py-1">
              <p class="font-medium">Commande #12347 confirmu00e9e</p>
              <p class="text-sm text-gray-400">Il y a 1 semaine</p>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Orders Tab -->
      <div id="orders-tab" class="account-tab hidden">
        <div class="bg-gray-800 rounded-lg p-6">
          <h2 class="text-xl font-semibold mb-6">Mes commandes</h2>
          
          <div class="space-y-6">
            <div class="border border-gray-700 rounded-lg overflow-hidden">
              <div class="bg-gray-700 p-4 flex justify-between items-center">
                <div>
                  <p class="font-medium">Commande #12345</p>
                  <p class="text-sm text-gray-400">Passu00e9e le 15/05/2023</p>
                </div>
                <span class="px-3 py-1 bg-green-500 text-white text-sm rounded-full">Livru00e9e</span>
              </div>
              <div class="p-4">
                <div class="flex justify-between mb-2">
                  <span class="text-gray-400">Total:</span>
                  <span class="font-medium">65 000 CFA</span>
                </div>
                <div class="flex justify-between mb-4">
                  <span class="text-gray-400">Articles:</span>
                  <span>3 produits</span>
                </div>
                <button class="btn w-full">Voir les du00e9tails</button>
              </div>
            </div>
            
            <div class="border border-gray-700 rounded-lg overflow-hidden">
              <div class="bg-gray-700 p-4 flex justify-between items-center">
                <div>
                  <p class="font-medium">Commande #12346</p>
                  <p class="text-sm text-gray-400">Passu00e9e le 10/05/2023</p>
                </div>
                <span class="px-3 py-1 bg-yellow-500 text-white text-sm rounded-full">En livraison</span>
              </div>
              <div class="p-4">
                <div class="flex justify-between mb-2">
                  <span class="text-gray-400">Total:</span>
                  <span class="font-medium">42 500 CFA</span>
                </div>
                <div class="flex justify-between mb-4">
                  <span class="text-gray-400">Articles:</span>
                  <span>2 produits</span>
                </div>
                <button class="btn w-full">Voir les du00e9tails</button>
              </div>
            </div>
            
            <div class="border border-gray-700 rounded-lg overflow-hidden">
              <div class="bg-gray-700 p-4 flex justify-between items-center">
                <div>
                  <p class="font-medium">Commande #12347</p>
                  <p class="text-sm text-gray-400">Passu00e9e le 05/05/2023</p>
                </div>
                <span class="px-3 py-1 bg-blue-500 text-white text-sm rounded-full">Confirmu00e9e</span>
              </div>
              <div class="p-4">
                <div class="flex justify-between mb-2">
                  <span class="text-gray-400">Total:</span>
                  <span class="font-medium">37 500 CFA</span>
                </div>
                <div class="flex justify-between mb-4">
                  <span class="text-gray-400">Articles:</span>
                  <span>2 produits</span>
                </div>
                <button class="btn w-full">Voir les du00e9tails</button>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Profile Tab -->
      <div id="profile-tab" class="account-tab hidden">
        <div class="bg-gray-800 rounded-lg p-6">
          <h2 class="text-xl font-semibold mb-6">Mon profil</h2>
          
          <form class="space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label for="profile-name" class="block text-sm font-medium mb-1">Nom complet</label>
                <input 
                  type="text" 
                  id="profile-name" 
                  name="name" 
                  value="Pharmacie Centrale" 
                  class="w-full px-4 py-2 bg-gray-700 border border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary"
                />
              </div>
              <div>
                <label for="profile-email" class="block text-sm font-medium mb-1">Email</label>
                <input 
                  type="email" 
                  id="profile-email" 
                  name="email" 
                  value="contact@pharmaciecentrale.ci" 
                  class="w-full px-4 py-2 bg-gray-700 border border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary"
                />
              </div>
            </div>
            
            <div>
              <label for="profile-phone" class="block text-sm font-medium mb-1">Tu00e9lu00e9phone</label>
              <input 
                type="tel" 
                id="profile-phone" 
                name="phone" 
                value="+225 07 12 34 56 78" 
                class="w-full px-4 py-2 bg-gray-700 border border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary"
              />
            </div>
            
            <div>
              <label for="profile-pharmacy" class="block text-sm font-medium mb-1">Nom de la pharmacie</label>
              <input 
                type="text" 
                id="profile-pharmacy" 
                name="pharmacy" 
                value="Pharmacie Centrale Abidjan" 
                class="w-full px-4 py-2 bg-gray-700 border border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary"
              />
            </div>
            
            <div>
              <label for="profile-license" class="block text-sm font-medium mb-1">Numu00e9ro de licence</label>
              <input 
                type="text" 
                id="profile-license" 
                name="license" 
                value="PHM-CI-2023-1234" 
                class="w-full px-4 py-2 bg-gray-700 border border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary"
              />
            </div>
            
            <div class="pt-4">
              <button type="submit" class="btn">
                Mettre u00e0 jour le profil
              </button>
            </div>
          </form>
        </div>
      </div>
      
      <!-- Addresses Tab -->
      <div id="addresses-tab" class="account-tab hidden">
        <div class="bg-gray-800 rounded-lg p-6">
          <div class="flex justify-between items-center mb-6">
            <h2 class="text-xl font-semibold">Mes adresses</h2>
            <button class="btn btn-sm">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
              </svg>
              Ajouter une adresse
            </button>
          </div>
          
          <div class="space-y-6">
            <div class="border border-gray-700 rounded-lg p-4">
              <div class="flex justify-between items-start mb-4">
                <div>
                  <h3 class="font-semibold mb-1">Adresse principale</h3>
                  <p class="text-sm text-gray-400">Adresse de livraison par du00e9faut</p>
                </div>
                <span class="px-2 py-1 bg-primary text-primary-content text-xs rounded-full">Par du00e9faut</span>
              </div>
              <div class="space-y-1 mb-4">
                <p>Pharmacie Centrale Abidjan</p>
                <p>123 Boulevard Principal</p>
                <p>Cocody, Abidjan</p>
                <p>Cu00f4te d'Ivoire</p>
                <p>+225 07 12 34 56 78</p>
              </div>
              <div class="flex space-x-2">
                <button class="btn btn-sm bg-gray-700 hover:bg-gray-600">
                  Modifier
                </button>
                <button class="btn btn-sm bg-red-900 hover:bg-red-800 text-white">
                  Supprimer
                </button>
              </div>
            </div>
            
            <div class="border border-gray-700 rounded-lg p-4">
              <div class="flex justify-between items-start mb-4">
                <div>
                  <h3 class="font-semibold mb-1">Adresse secondaire</h3>
                  <p class="text-sm text-gray-400">Adresse de livraison alternative</p>
                </div>
              </div>
              <div class="space-y-1 mb-4">
                <p>Pharmacie Centrale - Succursale</p>
                <p>45 Rue des Jardins</p>
                <p>Plateau, Abidjan</p>
                <p>Cu00f4te d'Ivoire</p>
                <p>+225 05 98 76 54 32</p>
              </div>
              <div class="flex space-x-2">
                <button class="btn btn-sm bg-gray-700 hover:bg-gray-600">
                  Modifier
                </button>
                <button class="btn btn-sm bg-gray-700 hover:bg-gray-600">
                  Du00e9finir par du00e9faut
                </button>
                <button class="btn btn-sm bg-red-900 hover:bg-red-800 text-white">
                  Supprimer
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Login Modal (shown when user is not logged in) -->
  <div id="login-modal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 hidden">
    <div class="bg-gray-800 rounded-lg p-8 max-w-md w-full">
      <h2 class="text-2xl font-bold mb-6 text-center">Connexion</h2>
      
      <form id="login-form" class="space-y-4">
        <div>
          <label for="login-email" class="block text-sm font-medium mb-1">Email</label>
          <input 
            type="email" 
            id="login-email" 
            name="email" 
            required 
            class="w-full px-4 py-2 bg-gray-700 border border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary"
          />
        </div>
        
        <div>
          <label for="login-password" class="block text-sm font-medium mb-1">Mot de passe</label>
          <input 
            type="password" 
            id="login-password" 
            name="password" 
            required 
            class="w-full px-4 py-2 bg-gray-700 border border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary"
          />
        </div>
        
        <div class="flex items-center justify-between">
          <div class="flex items-center">
            <input 
              type="checkbox" 
              id="remember-me" 
              name="remember-me" 
              class="h-4 w-4 text-primary focus:ring-primary border-gray-600 bg-gray-700 rounded"
            />
            <label for="remember-me" class="ml-2 block text-sm">Se souvenir de moi</label>
          </div>
          <a href="#" class="text-sm text-primary hover:underline">Mot de passe oubliu00e9?</a>
        </div>
        
        <button type="submit" class="btn w-full py-3">
          Se connecter
        </button>
      </form>
      
      <div class="mt-6 text-center">
        <p class="text-sm text-gray-400">Vous n'avez pas de compte?</p>
        <a href="#" class="text-primary hover:underline">Cru00e9er un compte</a>
      </div>
    </div>
  </div>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Check if user is logged in
    const isLoggedIn = localStorage.getItem('currentUser') !== null;
    const loginModal = document.getElementById('login-modal');
    const loginForm = document.getElementById('login-form');
    const logoutBtn = document.getElementById('logout-btn');
    const userNameElement = document.querySelector('.user-name');
    const userEmailElement = document.querySelector('.user-email');
    
    // Tab navigation
    const tabButtons = document.querySelectorAll('.account-tab-btn');
    const tabs = document.querySelectorAll('.account-tab');
    
    // Show login modal if not logged in
    if (!isLoggedIn && loginModal) {
      loginModal.classList.remove('hidden');
    } else if (isLoggedIn) {
      // Update user info
      const user = JSON.parse(localStorage.getItem('currentUser'));
      if (userNameElement && userEmailElement && user) {
        userNameElement.textContent = user.pharmacyName || user.name;
        userEmailElement.textContent = user.email;
      }
    }
    
    // Login form submission
    if (loginForm) {
      loginForm.addEventListener('submit', (event) => {
        event.preventDefault();
        
        const email = document.getElementById('login-email').value;
        const password = document.getElementById('login-password').value;
        
        // In a real app, you would validate credentials against a server
        // For this demo, we'll use a mock user
        const mockUser = {
          id: 'user-001',
          name: 'Pharmacie Centrale',
          email: email,
          phone: '+225 07 12 34 56 78',
          role: 'customer',
          pharmacyName: 'Pharmacie Centrale Abidjan',
          pharmacyLicense: 'PHM-CI-2023-1234'
        };
        
        // Save user to localStorage
        localStorage.setItem('currentUser', JSON.stringify(mockUser));
        
        // Hide login modal and reload page
        if (loginModal) {
          loginModal.classList.add('hidden');
        }
        
        // Reload page to update UI
        window.location.reload();
      });
    }
    
    // Logout button
    if (logoutBtn) {
      logoutBtn.addEventListener('click', () => {
        // Clear user from localStorage
        localStorage.removeItem('currentUser');
        
        // Reload page to update UI
        window.location.reload();
      });
    }
    
    // Tab navigation
    tabButtons.forEach(button => {
      button.addEventListener('click', () => {
        // Remove active class from all buttons
        tabButtons.forEach(btn => {
          btn.classList.remove('bg-primary', 'text-primary-content');
          btn.classList.add('hover:bg-gray-700');
        });
        
        // Add active class to clicked button
        button.classList.add('bg-primary', 'text-primary-content');
        button.classList.remove('hover:bg-gray-700');
        
        // Hide all tabs
        tabs.forEach(tab => {
          tab.classList.add('hidden');
        });
        
        // Show selected tab
        const tabId = `${button.getAttribute('data-tab')}-tab`;
        const tab = document.getElementById(tabId);
        if (tab) {
          tab.classList.remove('hidden');
        }
      });
    });
  });
</script>