---
import Layout from '../../layouts/Layout.astro';
import { formatPrice } from '../../utils/format';

// In a real app, we would fetch orders from an API or database
// For this demo, we'll use mock data
const orders = [
  {
    id: 'order-001',
    date: new Date('2023-05-15'),
    status: 'delivered',
    total: 32000,
    items: 3
  },
  {
    id: 'order-002',
    date: new Date('2023-05-10'),
    status: 'processing',
    total: 23000,
    items: 2
  },
  {
    id: 'order-003',
    date: new Date('2023-05-05'),
    status: 'confirmed',
    total: 28500,
    items: 2
  }
];

// Format date
const formatDate = (date) => {
  return new Intl.DateTimeFormat('fr-FR', {
    day: '2-digit',
    month: '2-digit',
    year: 'numeric'
  }).format(date);
};

// Get status label and color
const getStatusInfo = (status) => {
  switch (status) {
    case 'pending':
      return { label: 'En attente', color: 'bg-gray-500' };
    case 'confirmed':
      return { label: 'Confirmu00e9e', color: 'bg-blue-500' };
    case 'processing':
      return { label: 'En pru00e9paration', color: 'bg-yellow-500' };
    case 'shipped':
      return { label: 'Expiu00e9diu00e9e', color: 'bg-indigo-500' };
    case 'delivered':
      return { label: 'Livru00e9e', color: 'bg-green-500' };
    case 'cancelled':
      return { label: 'Annulu00e9e', color: 'bg-red-500' };
    default:
      return { label: 'Inconnu', color: 'bg-gray-500' };
  }
};
---

<Layout title="Mes Commandes - Boissons Express">
  <div class="mb-6">
    <a href="/mon-compte" class="text-gray-400 hover:text-primary flex items-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
      </svg>
      Retour u00e0 mon compte
    </a>
  </div>
  
  <h1 class="mb-8">Mes Commandes</h1>
  
  {orders.length > 0 ? (
    <div class="space-y-6">
      {orders.map(order => {
        const statusInfo = getStatusInfo(order.status);
        
        return (
          <div class="border border-gray-700 rounded-lg overflow-hidden">
            <div class="bg-gray-700 p-4 flex justify-between items-center">
              <div>
                <p class="font-medium">Commande #{order.id}</p>
                <p class="text-sm text-gray-400">Passu00e9e le {formatDate(order.date)}</p>
              </div>
              <span class={`px-3 py-1 ${statusInfo.color} text-white text-sm rounded-full`}>
                {statusInfo.label}
              </span>
            </div>
            <div class="p-4">
              <div class="flex justify-between mb-2">
                <span class="text-gray-400">Total:</span>
                <span class="font-medium">{formatPrice(order.total)}</span>
              </div>
              <div class="flex justify-between mb-4">
                <span class="text-gray-400">Articles:</span>
                <span>{order.items} produits</span>
              </div>
              <a href={`/commandes/${order.id}`} class="btn w-full">Voir les du00e9tails</a>
            </div>
          </div>
        );
      })}
    </div>
  ) : (
    <div class="text-center py-12 bg-gray-800 rounded-lg">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mx-auto mb-4 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
      </svg>
      <h2 class="text-xl font-semibold mb-2">Aucune commande</h2>
      <p class="text-gray-400 mb-4">Vous n'avez pas encore passu00e9 de commande.</p>
      <a href="/produits" class="btn">Voir les produits</a>
    </div>
  )}
</Layout>