---
import Layout from '../../layouts/Layout.astro';
import OrderDetails from '../../components/OrderDetails.astro';

// Enable server-side rendering for this page
export const prerender = false;

// Get the order ID from the URL
const { id } = Astro.params;

// In a real app, we would fetch the order from an API or database
// For this demo, we'll use mock data
const order = {
  id: id || 'order-001',
  userId: 'user-001',
  items: [
    { productId: 'prod-001', quantity: 2 },
    { productId: 'prod-004', quantity: 1 }
  ],
  totalAmount: 32000,
  status: 'delivered',
  shippingAddress: {
    street: '123 Boulevard Principal',
    city: 'Abidjan',
    region: 'Cocody',
    country: 'Cu00f4te d\'Ivoire'
  },
  paymentMethod: 'mobile',
  createdAt: new Date('2023-05-15')
};
---

<Layout title={`Commande #${order.id} - Boissons Express`}>
  <div class="mb-6">
    <a href="/mon-compte" class="text-gray-400 hover:text-primary flex items-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
      </svg>
      Retour u00e0 mon compte
    </a>
  </div>
  
  <h1 class="mb-8">Du00e9tails de la commande</h1>
  
  <OrderDetails order={order} />
  
  <div class="mt-8 flex justify-center">
    <button id="track-order-btn" class="btn mr-4">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
      </svg>
      Suivre la livraison
    </button>
    
    <button id="contact-support-btn" class="btn bg-gray-700 hover:bg-gray-600">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
      </svg>
      Contacter le support
    </button>
  </div>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const trackOrderBtn = document.getElementById('track-order-btn');
    const contactSupportBtn = document.getElementById('contact-support-btn');
    
    if (trackOrderBtn) {
      trackOrderBtn.addEventListener('click', () => {
        alert('Fonctionnalitu00e9 de suivi de livraison en cours de du00e9veloppement.');
      });
    }
    
    if (contactSupportBtn) {
      contactSupportBtn.addEventListener('click', () => {
        window.location.href = '/contact';
      });
    }
  });
</script>
